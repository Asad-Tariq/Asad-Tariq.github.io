source 'https://rubygems.org'

group :jekyll_plugins do
  gem 'jekyll'
  gem 'jekyll-feed'
  gem 'jekyll-sitemap'
  gem 'jekyll-redirect-from'
  gem 'jemoji'
  gem 'webrick', '~> 1.8'
end

gem 'github-pages'

# Windows has no system timezone database; tzinfo needs this gem to find one.
gem 'tzinfo-data', platforms: [:mingw, :mswin, :x64_mingw, :jruby]
